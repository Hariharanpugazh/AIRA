generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String?
  emailVerified  DateTime?       @map("email_verified") @db.Timestamp(6)
  image          String?
  phone          String?
  ownerId        String?         @map("owner_id")
  roleId         String?         @map("role_id")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  apiKeys        ApiKey[]
  activities     AuditLog[]      @relation("AuditActor")
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  configs        Config[]
  projects       Project[]       @relation("ProjectOwner")
  owner          User?           @relation("UserOwner", fields: [ownerId], references: [id])
  members        User[]          @relation("UserOwner")
  role           Role?           @relation(fields: [roleId], references: [id])

  @@index([ownerId], map: "idx_users_owner_id")
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamp(6)

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @map("user_id")
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model Role {
  id          String  @id
  name        String  @unique
  description String?
  permissions String?
  isSystem    Boolean @default(false) @map("is_system")
  users       User[]

  @@map("roles")
}

model Project {
  id                 String              @id
  shortId            String?             @unique(map: "idx_projects_short_id") @map("short_id")
  userId             String?             @map("user_id")
  name               String
  description        String?
  status             String              @default("active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamp(6)
  agents             Agent[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  autoRecordRules    AutoRecordingRule[]
  callLogs           CallLog[]
  configs            Config[]
  egresses           EgressRecord[]
  ingresses          IngressRecord[]
  layoutTemplates    LayoutTemplate[]
  participantRecords ParticipantRecord[]
  aiConfig           ProjectAiConfig?
  user               User?               @relation("ProjectOwner", fields: [userId], references: [id])
  roomTemplates      RoomTemplate[]
  liveSessions       LiveSession[]
  transcripts        Transcript[]
  webhookEvents      WebhookEvent[]

  @@index([userId], map: "idx_projects_user_id")
  @@map("projects")
}

model ProjectAiConfig {
  projectId   String  @id @map("project_id")
  sttMode     String? @map("stt_mode")
  sttProvider String? @map("stt_provider")
  sttModel    String? @map("stt_model")
  ttsMode     String? @map("tts_mode")
  ttsProvider String? @map("tts_provider")
  ttsModel    String? @map("tts_model")
  ttsVoice    String? @map("tts_voice")
  llmMode     String? @map("llm_mode")
  llmProvider String? @map("llm_provider")
  llmModel    String? @map("llm_model")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_ai_configs")
}

model LiveSession {
  sid                String              @id
  roomName           String              @map("room_name")
  status             String
  startTime          DateTime            @map("start_time") @db.Timestamp(6)
  endTime            DateTime?           @map("end_time") @db.Timestamp(6)
  duration           Int                 @default(0)
  totalParticipants  Int                 @default(0) @map("total_participants")
  activeParticipants Int                 @default(0) @map("active_participants")
  projectId          String?             @map("project_id")
  features           String?
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  participantRecords ParticipantRecord[]
  project            Project?            @relation(fields: [projectId], references: [id])
  transcripts        Transcript[]

  @@index([projectId], map: "idx_sessions_project_id")
  @@index([roomName], map: "idx_sessions_room_name")
  @@index([startTime], map: "idx_sessions_start_time")
  @@map("sessions")
}

model ParticipantRecord {
  id             String      @id
  sessionId      String      @map("session_id")
  identity       String
  status         String
  joinedAt       DateTime    @map("joined_at") @db.Timestamp(6)
  leftAt         DateTime?   @map("left_at") @db.Timestamp(6)
  platform       String?
  browser        String?
  connectionType String?     @map("connection_type")
  projectId      String?     @map("project_id")
  country        String?
  region         String?
  project        Project?    @relation(fields: [projectId], references: [id])
  session        LiveSession @relation(fields: [sessionId], references: [sid], onDelete: Cascade)

  @@index([sessionId])
  @@index([projectId])
  @@map("participant_records")
}

model AnalyticsSnapshot {
  id                String   @id
  timestamp         DateTime @default(now()) @db.Timestamp(6)
  activeRooms       Int      @default(0) @map("active_rooms")
  totalParticipants Int      @default(0) @map("total_participants")
  cpuLoad           Float?   @map("cpu_load")
  memoryUsage       Float?   @map("memory_usage")

  @@index([timestamp], map: "idx_analytics_snapshots_timestamp")
  @@map("analytics_snapshots")
}

model SipTrunk {
  id        String   @id
  name      String
  numbers   String?
  sipUri    String?  @map("sip_uri")
  sipServer String?  @map("sip_server")
  username  String?
  password  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("sip_trunks")
}

model DispatchRule {
  id        String   @id
  name      String
  ruleType  String   @map("rule_type")
  trunkId   String?  @map("trunk_id")
  agentId   String?  @map("agent_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("dispatch_rules")
}

model RoomTemplate {
  id          String   @id
  projectId   String?  @map("project_id")
  name        String
  description String?
  config      String
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "idx_room_templates_project_id")
  @@map("room_templates")
}

model LayoutTemplate {
  id         String   @id
  projectId  String?  @map("project_id")
  name       String
  layoutType String   @map("layout_type")
  config     String?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  project    Project? @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "idx_layout_templates_project_id")
  @@map("layout_templates")
}

model AutoRecordingRule {
  id          String   @id
  projectId   String?  @map("project_id")
  name        String
  roomPattern String?  @map("room_pattern")
  egressType  String   @map("egress_type")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "idx_auto_recording_rules_project_id")
  @@map("auto_recording_rules")
}

model ServiceAccount {
  id               String   @id
  name             String
  clientId         String   @unique @map("client_id")
  clientSecretHash String   @map("client_secret_hash")
  permissions      String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("service_accounts")
}

model StorageConfig {
  id          String   @id
  name        String
  storageType String   @map("storage_type")
  bucket      String
  region      String?
  endpoint    String?
  accessKey   String?  @map("access_key")
  secretKey   String?  @map("secret_key")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("storage_configs")
}

model Region {
  id         String   @id
  regionName String   @map("region_name")
  regionCode String   @unique @map("region_code")
  livekitUrl String?  @map("livekit_url")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("regions")
}

model Agent {
  id                  String          @id
  agentId             String          @unique @map("agent_id")
  displayName         String          @map("display_name")
  image               String
  entrypoint          String?
  instructions        String?
  welcomeMessage      String?         @map("welcome_message")
  voice               String?
  model               String?
  config              String?         @default("{}")
  envVars             String?         @default("{}") @map("env_vars")
  livekitPermissions  String?         @default("{}") @map("livekit_permissions")
  defaultRoomBehavior String?         @default("auto") @map("default_room_behavior")
  autoRestartPolicy   String?         @default("always") @map("auto_restart_policy")
  resourceLimits      String?         @default("{}") @map("resource_limits")
  isEnabled           Boolean         @default(true) @map("is_enabled")
  projectId           String?         @map("project_id")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  instances           AgentInstance[]
  logs                AgentLog[]
  metrics             AgentMetric[]
  rooms               AgentRoom[]
  project             Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "idx_agents_project_id")
  @@map("agents")
}

model AgentInstance {
  id            String        @id
  agentId       String        @map("agent_id")
  instanceId    String        @unique @map("instance_id")
  containerId   String?       @map("container_id")
  processPid    Int?          @map("process_pid")
  status        String        @default("stopped")
  lastHeartbeat DateTime?     @map("last_heartbeat") @db.Timestamp(6)
  exitCode      Int?          @map("exit_code")
  crashReason   String?       @map("crash_reason")
  startedAt     DateTime?     @map("started_at") @db.Timestamp(6)
  stoppedAt     DateTime?     @map("stopped_at") @db.Timestamp(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime      @default(now()) @map("updated_at") @db.Timestamp(6)
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  logs          AgentLog[]
  metrics       AgentMetric[]
  rooms         AgentRoom[]

  @@index([agentId], map: "idx_agent_instances_agent_id")
  @@index([status], map: "idx_agent_instances_status")
  @@map("agent_instances")
}

model AgentLog {
  id         String        @id
  agentId    String        @map("agent_id")
  instanceId String        @map("instance_id")
  logLevel   String?       @default("info") @map("log_level")
  message    String
  timestamp  DateTime      @default(now()) @db.Timestamp(6)
  agent      Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  instance   AgentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([agentId], map: "idx_agent_logs_agent_id")
  @@index([instanceId], map: "idx_agent_logs_instance_id")
  @@index([timestamp], map: "idx_agent_logs_timestamp")
  @@map("agent_logs")
}

model AgentMetric {
  id          String        @id
  agentId     String        @map("agent_id")
  instanceId  String        @map("instance_id")
  metricName  String        @map("metric_name")
  metricValue Float?        @map("metric_value")
  unit        String?
  timestamp   DateTime      @default(now()) @db.Timestamp(6)
  agent       Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  instance    AgentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([agentId], map: "idx_agent_metrics_agent_id")
  @@index([instanceId], map: "idx_agent_metrics_instance_id")
  @@index([timestamp], map: "idx_agent_metrics_timestamp")
  @@map("agent_metrics")
}

model AgentRoom {
  id         String         @id
  agentId    String         @map("agent_id")
  instanceId String?        @map("instance_id")
  roomName   String         @map("room_name")
  joinedAt   DateTime?      @map("joined_at") @db.Timestamp(6)
  leftAt     DateTime?      @map("left_at") @db.Timestamp(6)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  agent      Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  instance   AgentInstance? @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([agentId], map: "idx_agent_rooms_agent_id")
  @@index([roomName], map: "idx_agent_rooms_room_name")
  @@map("agent_rooms")
}

model ApiKey {
  id         String   @id
  userId     String?  @map("user_id")
  projectId  String?  @map("project_id")
  name       String
  key        String   @unique
  secret     String?
  secretHash String   @map("secret_hash")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  isActive   Boolean  @default(true) @map("is_active")
  project    Project? @relation(fields: [projectId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([key], map: "idx_api_keys_key")
  @@index([userId], map: "idx_api_keys_user_id")
  @@index([projectId], map: "idx_api_keys_project_id")
  @@map("api_keys")
}

model Room {
  id              String   @id
  roomName        String   @unique @map("room_name")
  roomSid         String?  @map("room_sid")
  maxParticipants Int?     @map("max_participants")
  emptyTimeout    Int?     @map("empty_timeout")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  isActive        Boolean  @default(true) @map("is_active")

  @@index([roomName], map: "idx_rooms_name")
  @@map("rooms")
}

model IngressRecord {
  id                    String    @id
  name                  String
  inputType             String    @map("input_type")
  roomName              String?   @map("room_name")
  streamKey             String?   @map("stream_key")
  url                   String?
  isEnabled             Boolean   @default(true) @map("is_enabled")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  projectId             String?   @map("project_id")

  // LiveKit Ingress tracking fields
  participantIdentity   String?   @map("participant_identity")
  participantName       String?   @map("participant_name")
  resourceId            String?   @map("resource_id")
  roomId                String?   @map("room_id")
  reusable              Boolean   @default(false)
  status                String    @default("endpoint_inactive")
  startedAt             DateTime? @map("started_at") @db.Timestamp(6)
  endedAt               DateTime? @map("ended_at") @db.Timestamp(6)
  error                 String?
  audioCodec            String?   @map("audio_codec")
  videoCodec            String?   @map("video_codec")
  audioBitrate          Int?      @map("audio_bitrate")
  videoBitrate          Int?      @map("video_bitrate")
  videoResolution       String?   @map("video_resolution")
  trackCount            Int       @default(0) @map("track_count")
  trackSids             String?   @map("track_sids")
  userId                String?   @map("user_id")

  project               Project?  @relation(fields: [projectId], references: [id])

  @@index([roomName], map: "idx_ingress_room")
  @@index([projectId], map: "idx_ingress_project")
  @@index([status], map: "idx_ingress_status")
  @@index([participantIdentity], map: "idx_ingress_participant_identity")
  @@index([resourceId], map: "idx_ingress_resource_id")
  @@index([userId], map: "idx_ingress_user_id")
  @@index([startedAt], map: "idx_ingress_started_at")
  @@map("ingress")
}

model EgressRecord {
  id                    String    @id
  name                  String
  egressType            String    @map("egress_type")
  roomName              String?   @map("room_name")
  outputType            String?   @map("output_type")
  outputUrl             String?   @map("output_url")
  isActive              Boolean   @default(false) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  projectId             String?   @map("project_id")

  // LiveKit Egress tracking fields
  egressId              String?   @unique @map("egress_id")
  roomId                String?   @map("room_id")
  sourceType            String    @default("room_composite") @map("source_type")
  statusDetail          String?   @map("status_detail")
  startedAt             DateTime? @map("started_at") @db.Timestamp(6)
  endedAt               DateTime? @map("ended_at") @db.Timestamp(6)
  errorCode             String?   @map("error_code")
  errorMessage          String?   @map("error_message")
  fileResults           String?   @map("file_results")
  streamResults         String?   @map("stream_results")
  segmentResults        String?   @map("segment_results")
  imageResults          String?   @map("image_results")
  layout                String?
  audioOnly             Boolean   @default(false) @map("audio_only")
  videoOnly             Boolean   @default(false) @map("video_only")
  participantIdentity   String?   @map("participant_identity")
  trackId               String?   @map("track_id")
  webUrl                String?   @map("web_url")
  userId                String?   @map("user_id")

  project               Project?  @relation(fields: [projectId], references: [id])

  @@index([roomName], map: "idx_egress_room")
  @@index([projectId], map: "idx_egress_project")
  @@index([egressId], map: "idx_egress_egress_id")
  @@index([roomId], map: "idx_egress_room_id")
  @@index([sourceType], map: "idx_egress_source_type")
  @@index([participantIdentity], map: "idx_egress_participant_identity")
  @@index([trackId], map: "idx_egress_track_id")
  @@index([userId], map: "idx_egress_user_id")
  @@index([startedAt], map: "idx_egress_started_at")
  @@index([statusDetail], map: "idx_egress_status_detail")
  @@map("egress")
}

model Sip {
  id          String   @id
  name        String
  trunkId     String?  @map("trunk_id")
  phoneNumber String?  @map("phone_number")
  roomName    String?  @map("room_name")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([roomName], map: "idx_sip_room")
  @@map("sip")
}

model Config {
  id          String   @id
  userId      String?  @map("user_id")
  projectId   String?  @map("project_id")
  serviceName String   @map("service_name")
  configKey   String   @map("config_key")
  configValue String?  @map("config_value")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  project     Project? @relation(fields: [projectId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([serviceName, configKey])
  @@index([serviceName], map: "idx_configs_service")
  @@index([userId], map: "idx_configs_user_id")
  @@index([projectId], map: "idx_configs_project_id")
  @@map("configs")
}

model Metric {
  id          String   @id
  metricName  String   @map("metric_name")
  metricValue Float?   @map("metric_value")
  labels      String?
  timestamp   DateTime @default(now()) @db.Timestamp(6)

  @@index([metricName], map: "idx_metrics_name")
  @@index([timestamp], map: "idx_metrics_timestamp")
  @@map("metrics")
}

model Transcript {
  id                  String      @id
  sessionId           String      @map("session_id")
  roomName            String      @map("room_name")
  participantIdentity String?     @map("participant_identity")
  text                String
  timestamp           DateTime    @default(now()) @db.Timestamp(6)
  language            String?
  isFinal             Boolean     @default(true) @map("is_final")
  projectId           String?     @map("project_id")
  project             Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session             LiveSession @relation(fields: [sessionId], references: [sid], onDelete: Cascade)

  @@index([sessionId], map: "idx_transcripts_session_id")
  @@index([timestamp], map: "idx_transcripts_timestamp")
  @@map("transcripts")
}

model AuditLog {
  id         String   @id
  timestamp  DateTime @default(now()) @db.Timestamp(6)
  action     String
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   String?
  ipAddress  String?  @map("ip_address")
  projectId  String?  @map("project_id")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([timestamp], map: "idx_audit_logs_timestamp")
  @@index([action], map: "idx_audit_logs_action")
  @@index([projectId], map: "idx_audit_logs_project_id")
  @@map("audit_logs")
}

model WebhookEvent {
  id                  String            @id @db.VarChar(36)
  projectId           String?           @map("project_id")
  eventType           String            @map("event_type") @db.VarChar(100)
  payload             String
  processed           Boolean           @default(false)
  deliveryAttempts    Int               @default(0) @map("delivery_attempts")
  lastError           String?           @map("last_error")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamp(6)

  // LiveKit tracking fields
  sessionId           String?           @map("session_id")
  roomName            String?           @map("room_name")
  participantIdentity String?           @map("participant_identity")
  egressId            String?           @map("egress_id")
  ingressId           String?           @map("ingress_id")
  callId              String?           @map("call_id")
  sipCallId           String?           @map("sip_call_id")

  deliveries          WebhookDelivery[]
  project             Project?          @relation(fields: [projectId], references: [id])

  @@index([createdAt], map: "idx_webhook_events_created_at")
  @@index([processed], map: "idx_webhook_events_processed")
  @@index([eventType], map: "idx_webhook_events_event_type")
  @@index([projectId], map: "idx_webhook_events_project_id")
  @@index([sessionId], map: "idx_webhook_events_session_id")
  @@index([roomName], map: "idx_webhook_events_room_name")
  @@index([egressId], map: "idx_webhook_events_egress_id")
  @@index([ingressId], map: "idx_webhook_events_ingress_id")
  @@map("webhook_events")
}

model WebhookDelivery {
  id           String       @id @db.VarChar(36)
  eventId      String       @map("event_id") @db.VarChar(36)
  webhookId    String       @map("webhook_id") @db.VarChar(36)
  url          String
  statusCode   Int?         @map("status_code")
  responseBody String?      @map("response_body")
  errorMessage String?      @map("error_message")
  attemptedAt  DateTime     @default(now()) @map("attempted_at") @db.Timestamp(6)
  success      Boolean      @default(false)
  event        WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId], map: "idx_webhook_deliveries_event_id")
  @@index([attemptedAt], map: "idx_webhook_deliveries_attempted_at")
  @@index([success], map: "idx_webhook_deliveries_success")
  @@map("webhook_deliveries")
}

model ErrorLog {
  id         String    @id @db.VarChar(36)
  errorType  String    @map("error_type") @db.VarChar(100)
  message    String
  isResolved Boolean   @default(false) @map("is_resolved")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([createdAt], map: "idx_error_logs_created_at")
  @@index([isResolved], map: "idx_error_logs_is_resolved")
  @@index([errorType], map: "idx_error_logs_error_type")
  @@map("error_logs")
}

model CallLog {
  id                  String    @id
  callId              String    @map("call_id")
  fromNumber          String?   @map("from_number")
  toNumber            String    @map("to_number")
  direction           String
  startedAt           DateTime  @map("started_at") @db.Timestamp(6)
  endedAt             DateTime? @map("ended_at") @db.Timestamp(6)
  durationSeconds     Int?      @default(0) @map("duration_seconds")
  status              String    @default("ringing")
  trunkId             String?   @map("trunk_id")
  roomName            String?   @map("room_name")
  participantIdentity String?   @map("participant_identity")
  projectId           String?   @map("project_id")
  metadata            String?
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  // Extended SIP tracking fields
  sipCallId           String?   @map("sip_call_id")
  roomSid             String?   @map("room_sid")
  fromSipUri          String?   @map("from_sip_uri")
  toSipUri            String?   @map("to_sip_uri")
  hangupCause         String?   @map("hangup_cause")
  hangupSource        String?   @map("hangup_source")
  recordingUrl        String?   @map("recording_url")
  recordingDuration   Int?      @map("recording_duration")
  userId              String?   @map("user_id")

  project             Project?  @relation(fields: [projectId], references: [id])

  @@index([callId], map: "idx_call_logs_call_id")
  @@index([direction], map: "idx_call_logs_direction")
  @@index([startedAt], map: "idx_call_logs_started_at")
  @@index([trunkId], map: "idx_call_logs_trunk_id")
  @@index([projectId], map: "idx_call_logs_project_id")
  @@index([sipCallId], map: "idx_call_logs_sip_call_id")
  @@index([participantIdentity], map: "idx_call_logs_participant_identity")
  @@index([roomSid], map: "idx_call_logs_room_sid")
  @@index([userId], map: "idx_call_logs_user_id")
  @@index([status], map: "idx_call_logs_status")
  @@map("call_logs")
}
